  <script>
    // Wait for DOM to be fully loaded
    document.addEventListener('DOMContentLoaded', function () {
      try {
        // Parse the chart data passed from server
        const chartData = {
          categories: JSON.parse('<%- JSON.stringify(chartData.categories) %>'),
          series: JSON.parse('<%- JSON.stringify(chartData.series) %>')
        };

        // Validate data
        if (!chartData.series || !chartData.series[0] || !chartData.categories) {
          throw new Error('Invalid chart data structure');
        }

        const chartOptions = {
          series: [{
            name: chartData.series[0].name || 'Net Sales',
            data: chartData.series[0].data || []
          }],
          chart: {
            height: 300,
            type: 'area',
            toolbar: { show: false },
            animations: { enabled: true },
            events: {
              mounted: function () {
                console.log('Chart rendered successfully');
              },
              error: function (err) {
                console.error('Chart error:', err);
                displayChartError();
              }
            }
          },
          colors: ['#0d6efd'],
          dataLabels: { enabled: false },
          stroke: { curve: 'smooth', width: 2 },
          fill: {
            type: 'gradient',
            gradient: {
              shadeIntensity: 1,
              opacityFrom: 0.7,
              opacityTo: 0.3,
            }
          },
          xaxis: {
            categories: chartData.categories,
            labels: {
              formatter: function (value) {
                return value || '';
              }
            }
          },
          yaxis: {
            labels: {
              formatter: function (value) {
                return 'रु ' + value.toLocaleString();
              }
            }
          },
          tooltip: {
            y: {
              formatter: function (value) {
                return 'रु ' + value.toLocaleString();
              }
            }
          },
          noData: {
            text: 'No sales data available',
            align: 'center'
          }
        };

        // Initialize chart
        const chartElement = document.querySelector('#revenue-chart');
        if (chartElement) {
          if (window.salesChart) {
            window.salesChart.destroy();
          }
          window.salesChart = new ApexCharts(chartElement, chartOptions);
          window.salesChart.render();
        } else {
          throw new Error('Chart container not found');
        }
      } catch (error) {
        console.error('Chart initialization failed:', error);
        displayChartError();
      }
    });

    // Error display function
    function displayChartError() {
      const container = document.querySelector('#revenue-chart');
      if (container) {
        container.innerHTML = `
                <div class="alert alert-danger" style="height: 300px; display: flex; align-items: center; justify-content: center;">
                    Failed to load sales chart. Please try refreshing the page.
                </div>
            `;
      }
    }
  </script>
